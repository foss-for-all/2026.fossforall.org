---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import SiteLayout from '../layouts/site-layout.astro';
import type { Locale } from '../i18n/config';

interface Props {
	entry: CollectionEntry<'pages'>;
	locale: Locale;
}

const { entry, locale } = Astro.props;
const { Content } = await render(entry);
---

<SiteLayout locale={locale} path={entry.data.slug} title={entry.data.title} description={entry.data.description}>
	<main class="mx-auto max-w-4xl px-6 py-16 lg:px-8">
		<header class="mb-12 border-b pb-8">

			<h1 class="mt-3 font-heading text-4xl font-black tracking-[-0.04em] text-balance sm:text-5xl">
				{entry.data.title}
			</h1>
			<p class="mt-4 max-w-2xl text-lg leading-8 text-muted-foreground">
				{entry.data.description}
			</p>
		</header>

		<article class="mdx-content max-w-none">
			<Content />
		</article>
	</main>
</SiteLayout>
