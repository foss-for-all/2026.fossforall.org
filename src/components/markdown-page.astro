---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import SiteLayout from '../layouts/site-layout.astro';
import type { Locale } from '../i18n/config';

interface Props {
	entry: CollectionEntry<'pages'>;
	locale: Locale;
}

const { entry, locale } = Astro.props;
const { Content } = await render(entry);
---

<SiteLayout locale={locale} path={entry.data.slug} title={entry.data.title} description={entry.data.description}>
	<main class="mx-auto max-w-3xl px-6 py-16 lg:px-8">
		<article class="prose prose-neutral max-w-none dark:prose-invert">
			<Content />
		</article>
	</main>
</SiteLayout>
