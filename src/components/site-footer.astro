---
import type { Locale } from '../i18n/config';
import { getFooter } from '../i18n/footer';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const footer = getFooter(locale);
---

<footer class="border-t border-border/80 bg-muted/30">
	<div class="mx-auto grid max-w-7xl gap-8 px-6 py-10 lg:grid-cols-[1fr_auto] lg:px-8">
		<div>
			<p class="font-heading text-lg font-black tracking-[-0.03em] text-foreground">
				{footer.title}
			</p>
			<p class="mt-3 max-w-2xl text-sm leading-6 text-muted-foreground">
				{footer.copyright}
			</p>
		</div>

		<nav aria-label="Footer" class="flex flex-col gap-2 text-sm lg:items-end">
			{footer.links.map((link) => (
				<a
					href={link.href}
					target={link.external ? '_blank' : undefined}
					rel={link.external ? 'noreferrer' : undefined}
					class="text-muted-foreground transition-colors hover:text-foreground"
				>
					{link.label}
				</a>
			))}
		</nav>
	</div>
</footer>
