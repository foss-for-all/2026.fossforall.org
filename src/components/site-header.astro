---
import { Button } from '@/components/ui/button';
import { DesktopNav } from './desktop-nav';
import { MobileNav } from './mobile-nav';
import type { Locale } from '../i18n/config';
import { getLanguageOptions } from '../i18n/utils';

interface Props {
	locale: Locale;
	path?: string;
	labels: {
		headerTitle: string;
		siteName: string;
		eventSummary: string;
		register: string;
		openNavigation: string;
	};
	navItems: Array<{ label: string; href: string }>;
}

const { locale, path = '', labels, navItems } = Astro.props;
const languageOptions = getLanguageOptions(locale, path);
---

<header class="sticky top-0 z-50 border-b border-border/80 bg-background/88 backdrop-blur supports-[backdrop-filter]:bg-background/72">
	<div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4 lg:px-8">
		<a href="/" class="text-sm font-black text-foreground">
			{labels.headerTitle}
		</a>

		<div class="hidden md:block">
			<DesktopNav items={navItems} />
		</div>

		<div class="flex items-center gap-3">
			<nav aria-label="Language" class="hidden items-center gap-1 text-sm md:flex">
				{languageOptions.map((option) => (
					<a
						href={option.href}
						aria-current={option.current ? 'page' : undefined}
						class:list={[
							'rounded-full px-3 py-2 transition-colors',
							option.current
								? 'bg-primary text-primary-foreground'
								: 'text-muted-foreground hover:bg-accent hover:text-foreground',
						]}
					>
						{option.label}
					</a>
				))}
			</nav>
			<div class="md:hidden">
				<MobileNav
					client:load
					items={navItems}
					title={labels.siteName}
					description={labels.eventSummary}
					registerLabel={labels.register}
					openLabel={labels.openNavigation}
				/>
			</div>
			<Button asChild className="hidden rounded-full md:inline-flex">
				<a href="#register">{labels.register}</a>
			</Button>
		</div>
	</div>
</header>
