---
import { Button } from '@/components/ui/button';
import { DesktopNav } from './desktop-nav';
import { LanguageSwitcher } from './language-switcher';
import { MobileNav } from './mobile-nav';
import { ThemeToggle } from './theme-toggle';
import type { Locale } from '../i18n/config';
import type { NavigationItem } from '../i18n/navigation';
import { getLanguageOptions } from '../i18n/utils';

interface Props {
	locale: Locale;
	path?: string;
	labels: {
		headerTitle: string;
		siteName: string;
		eventSummary: string;
		register: string;
		openNavigation: string;
		language: string;
		theme: string;
		lightTheme: string;
		darkTheme: string;
		systemTheme: string;
	};
	navItems: NavigationItem[];
}

const { locale, path = '', labels, navItems } = Astro.props;
const languageOptions = getLanguageOptions(locale, path);
const themeLabels = {
	theme: labels.theme,
	lightTheme: labels.lightTheme,
	darkTheme: labels.darkTheme,
	systemTheme: labels.systemTheme,
};
---

<header class="sticky top-0 z-50 border-b border-border/80 bg-background/88 backdrop-blur supports-[backdrop-filter]:bg-background/72">
	<div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4 lg:px-8">
		<a href="/" class="text-sm font-black text-foreground">
			{labels.headerTitle}
		</a>

		<div class="hidden md:block">
			<DesktopNav client:load items={navItems} />
		</div>

		<div class="flex items-center gap-3">
			<ThemeToggle client:load labels={themeLabels} />
			<LanguageSwitcher client:load label={labels.language} options={languageOptions} />
			<div class="md:hidden">
				<MobileNav
					client:load
					items={navItems}
					languageOptions={languageOptions}
					title={labels.siteName}
					description={labels.eventSummary}
					registerLabel={labels.register}
					openLabel={labels.openNavigation}
					languageLabel={labels.language}
				/>
			</div>
			<Button asChild className="hidden rounded-full md:inline-flex">
				<a href="#register">{labels.register}</a>
			</Button>
		</div>
	</div>
</header>
