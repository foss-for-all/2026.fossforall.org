---
import { getCollection } from 'astro:content';
import MarkdownPage from '../../components/markdown-page.astro';

export async function getStaticPaths() {
	const pages = await getCollection('pages', ({ data }) => data.locale === 'en');

	return pages.map((entry) => ({
		params: { slug: entry.data.path },
		props: { entry },
	}));
}

const { entry } = Astro.props;
---

<MarkdownPage entry={entry} locale="en" />
